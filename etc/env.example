# ---- データベース設定 ----
# POSTGRES_PASSWORD を空のままにすると install.sh が自動でパスワードを生成します。
# 既存の DB に接続する場合は POSTGRES_USER / POSTGRES_PASSWORD / POSTGRES_DB を設定してください。
POSTGRES_USER=video_ratings
POSTGRES_PASSWORD=
POSTGRES_DB=video_ratings

# ---- Samba 認証情報（必須） ----
SMB_USERNAME=
SMB_PASSWORD=

# ---- アップロードファイルの保存先 ----
UPLOAD_DIR=/var/lib/video-ratings/uploads

# ---- ポート設定 ----
# バックエンド（uvicorn）のリッスンポート（デフォルト: 8000）
# BACKEND_PORT=8000
# nginx のリッスンポート（デフォルト: 80）
# NGINX_PORT=80

# ---- Basic認証 ----
# Basic認証を有効にする場合は BASIC_AUTH_ENABLED=true にして
# BASIC_AUTH_USER と BASIC_AUTH_PASSWORD を設定してください。
# BASIC_AUTH_ENABLED=false
# BASIC_AUTH_USER=admin
# BASIC_AUTH_PASSWORD=

# ---- セッション認証 ----
# セッション署名用の秘密鍵（必須）
# install.sh が自動で生成します。手動で設定する場合は十分に長いランダム文字列を使用してください。
SECRET_KEY=

# セッションタイムアウト（秒）。デフォルト: 7200（2時間）
# SESSION_TIMEOUT_SECONDS=7200

# HTTPS 環境の場合は true に設定してください（デフォルト: false）
# true にすると Cookie に Secure フラグが付与され、HTTPS 接続でのみ送信されます。
# COOKIE_SECURE=false

# ---- フロントエンド配信 ----
# FastAPI が SPA 静的ファイルを配信するディレクトリ（デフォルト: 自動設定）
# FRONTEND_DIR=/opt/video-ratings/current/frontend/dist
